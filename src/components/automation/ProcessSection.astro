---
import { processSteps } from '../../data/automation';
import SectionIntro from '../studio/SectionIntro.astro';
import Container from '../studio/Container.astro';
import FadeIn from '../studio/FadeIn.astro';
import FadeInStagger from '../studio/FadeInStagger.astro';
import Border from '../studio/Border.astro';
---

<div id="automation-process">
  <SectionIntro
    eyebrow="Cómo funciona"
    title="De idea a agente en semanas."
    class="mt-24 sm:mt-32 lg:mt-40"
  >
    <p>
      Un proceso claro y probado para que tu primer agente esté operando
      <strong class="font-semibold text-neutral-950">lo más rápido posible</strong>, sin sacrificar
      calidad.
    </p>
  </SectionIntro>
  <Container class="mt-16">
    <FadeInStagger as="ol" role="list" class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {processSteps.map((step) => (
        <FadeIn as="li">
          <Border position="left" class="pl-8">
            <span class="font-display text-base font-semibold text-neutral-950">{step.number}</span>
            <h3 class="mt-6 font-display text-2xl font-semibold text-neutral-950">{step.title}</h3>
            <p class="mt-4 text-base text-neutral-600">{step.description}</p>
          </Border>
        </FadeIn>
      ))}
    </FadeInStagger>
  </Container>
</div>
