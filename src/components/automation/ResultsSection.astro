---
import { results } from '../../data/automation';
import SectionIntro from '../studio/SectionIntro.astro';
import Container from '../studio/Container.astro';
import FadeIn from '../studio/FadeIn.astro';
import FadeInStagger from '../studio/FadeInStagger.astro';
import Border from '../studio/Border.astro';
---

<div id="automation-results">
  <SectionIntro
    eyebrow="Resultados"
    title="Antes y después."
    class="mt-24 sm:mt-32 lg:mt-40"
  />
  <Container class="mt-16">
    <FadeInStagger as="dl" class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:auto-cols-fr lg:grid-flow-col lg:grid-cols-none">
      {results.map((result) => (
        <FadeIn>
          <Border position="left" class="flex flex-col pl-8">
            <dt class="text-base text-neutral-600">{result.title}</dt>
            <dd class="mt-4 flex flex-wrap items-baseline gap-x-3 gap-y-1">
              <span class:list={[
                'font-display font-semibold text-neutral-400 line-through',
                result.compact ? 'text-xl sm:text-2xl' : 'text-2xl sm:text-3xl',
              ]}>{result.before}</span>
              <span class="text-neutral-300" aria-hidden="true">→</span>
              <span class:list={[
                'font-display font-semibold text-neutral-950',
                result.compact ? 'text-xl sm:text-2xl' : 'text-3xl sm:text-4xl',
              ]}>{result.after}</span>
            </dd>
          </Border>
        </FadeIn>
      ))}
    </FadeInStagger>
  </Container>
</div>
