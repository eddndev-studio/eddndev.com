---
import { painPoints } from '../../data/automation';
import SectionIntro from '../studio/SectionIntro.astro';
import Container from '../studio/Container.astro';
import GridList from '../studio/GridList.astro';
import GridListItem from '../studio/GridListItem.astro';
---

<div id="automation-problem">
  <SectionIntro
    eyebrow="El problema"
    title="Tu equipo merece mejor."
    class="mt-24 sm:mt-32 lg:mt-40"
  >
    <p>
      Tu equipo pasa horas en tareas repetitivas que una máquina podría hacer en segundos. Mientras
      tanto, los procesos críticos dependen de una sola persona, los datos viven en silos y
      <strong class="font-semibold text-neutral-950">escalar significa contratar más gente para
      hacer lo mismo</strong>.
    </p>
  </SectionIntro>
  <Container class="mt-16">
    <GridList>
      {painPoints.map((point) => (
        <GridListItem title={point.title}>{point.description}</GridListItem>
      ))}
    </GridList>
  </Container>
</div>
