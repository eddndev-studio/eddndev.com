---
import { capabilities } from '../../data/automation';
import SectionIntro from '../studio/SectionIntro.astro';
import Container from '../studio/Container.astro';
import GridList from '../studio/GridList.astro';
import GridListItem from '../studio/GridListItem.astro';
---

<div id="automation-solution">
  <SectionIntro
    eyebrow="La solución"
    title="Automatización a medida."
    class="mt-24 sm:mt-32 lg:mt-40"
  >
    <p>
      Diseño <strong class="font-semibold text-neutral-950">agentes
      inteligentes que entienden tu negocio</strong> — capturan información, toman decisiones basadas
      en tus reglas y ejecutan acciones reales en tus sistemas existentes.
    </p>
  </SectionIntro>
  <Container class="mt-16">
    <GridList>
      {capabilities.map((cap) => (
        <GridListItem title={cap.title}>{cap.description}</GridListItem>
      ))}
    </GridList>
  </Container>
</div>
