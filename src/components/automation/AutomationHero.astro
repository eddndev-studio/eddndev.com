---
import PageIntro from '../studio/PageIntro.astro';
import Container from '../studio/Container.astro';
import FadeIn from '../studio/FadeIn.astro';
import Button from '../studio/Button.astro';
---

<PageIntro eyebrow="Automatización" title="Agentes que trabajan.">
  <p>
    No vendo promesas de IA. Construyo agentes que capturan datos, toman decisiones y ejecutan
    acciones reales dentro de tu operación — <strong class="font-semibold text-neutral-950">sin
    intervención humana</strong>.
  </p>
</PageIntro>

<Container class="mt-10">
  <FadeIn class="flex flex-wrap items-center gap-x-6 gap-y-4">
    <Button href="/contact">Agenda una consulta gratis</Button>
    <a href="#automation-problem" class="group inline-flex items-center gap-2 text-sm font-semibold text-neutral-950 transition hover:text-neutral-600">
      Ver cómo funciona
      <svg aria-hidden="true" class="h-4 w-4 transition-transform group-hover:translate-y-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
    </a>
  </FadeIn>
</Container>
