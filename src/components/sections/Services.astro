---
import { services } from '../../data/services';

const colorMap: Record<string, { num: string; wash: string; tagline: string }> = {
  purple: { num: 'text-purple-400', wash: 'bg-gradient-to-r from-purple-500/10 via-purple-500/[0.03] to-transparent', tagline: 'group-hover:text-purple-200' },
  green:  { num: 'text-green-400',  wash: 'bg-gradient-to-r from-green-500/10 via-green-500/[0.03] to-transparent',   tagline: 'group-hover:text-green-200' },
  orange: { num: 'text-orange-400', wash: 'bg-gradient-to-r from-orange-500/10 via-orange-500/[0.03] to-transparent', tagline: 'group-hover:text-orange-200' },
  blue:   { num: 'text-blue-400',   wash: 'bg-gradient-to-r from-blue-500/10 via-blue-500/[0.03] to-transparent',     tagline: 'group-hover:text-blue-200' },
};
---

<section id="services" class="bg-[#050505] text-white border-t border-white/10 relative overflow-hidden">
    <!-- Stroke Draw: Large nested diamonds -->
    <svg aria-hidden="true" data-index-draw class="absolute top-[10%] right-[3%] w-64 h-64 lg:w-[500px] lg:h-[500px] pointer-events-none z-0" viewBox="0 0 200 200" fill="none">
        <rect x="30" y="30" width="140" height="140" rx="2" transform="rotate(45, 100, 100)" stroke="rgba(139,92,246,0.2)" stroke-width="1" class="draw-path" />
        <rect x="55" y="55" width="90" height="90" rx="2" transform="rotate(45, 100, 100)" stroke="rgba(168,85,247,0.25)" stroke-width="1.2" class="draw-path" />
        <circle cx="100" cy="100" r="20" stroke="rgba(192,132,252,0.3)" stroke-width="1.5" class="draw-path" />
    </svg>

    <div class="mx-auto max-w-[1800px] relative z-10">

        <!-- Header -->
        <div class="px-6 sm:px-12 py-24 lg:pt-32 lg:pb-16">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
                <div class="lg:col-span-5">
                    <div class="text-xs 2xl:text-sm font-mono text-purple-400 tracking-widest mb-4 reveal-text" data-readout>
                        [ 02 · SERVICIOS ]
                    </div>
                    <h2 class="text-4xl sm:text-5xl md:text-6xl lg:text-6xl 2xl:text-7xl font-black tracking-tighter leading-[0.9] reveal-text">
                        LO QUE <br> <span class="text-purple-400"><em>construyo</em>.</span>
                    </h2>
                </div>
                <div class="lg:col-span-7 flex flex-col justify-end pl-0 lg:pl-12">
                    <p class="text-lg sm:text-xl md:text-2xl lg:text-xl 2xl:text-2xl text-gray-300 font-light leading-relaxed max-w-2xl reveal-text">
                        Cuatro líneas de servicio, un mismo estándar: <span class="text-white font-medium">soluciones propias que escalan con tu negocio</span>.
                    </p>
                </div>
            </div>
        </div>

        <!-- Index rows -->
        <div class="pb-24 lg:pb-32">
            <div>
                {services.map((service) => {
                    const c = colorMap[service.color];
                    const isAutomation = service.id === 'agentes-de-automatizacion';
                    return (
                        <a
                            href={isAutomation ? "/automation" : `/services#${service.id}`}
                            data-service-card
                            data-magnetic-zone
                            data-cursor-text="VER MÁS"
                            class="group relative grid grid-cols-12 items-center gap-x-4 gap-y-2 px-6 sm:px-12 py-10 lg:py-14 overflow-hidden transition-colors hover:bg-white/[0.02]"
                        >
                            <span data-row-line aria-hidden="true" class="absolute top-0 left-0 block h-px w-full bg-white/10"></span>
                            <div class={`absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none ${c.wash}`}></div>

                            <span data-row-reveal class={`relative z-10 col-span-12 sm:col-span-1 font-mono text-xs tracking-widest ${c.num}`}>{service.number}</span>

                            <h3 data-row-reveal class="relative z-10 col-span-12 sm:col-span-6 text-3xl sm:text-5xl 2xl:text-6xl font-black tracking-tighter text-white group-hover:translate-x-3 transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]">
                                {service.title}
                            </h3>

                            <p data-row-reveal class={`relative z-10 col-span-12 sm:col-span-4 text-gray-500 font-light text-sm sm:text-base 2xl:text-lg ${c.tagline} transition-colors`}>
                                {service.tagline}
                            </p>

                            <div data-row-reveal class="relative z-10 hidden sm:flex sm:col-span-1 justify-end">
                                <div data-magnetic="0.5" class="w-12 h-12 2xl:w-14 2xl:h-14 rounded-full border border-white/15 flex items-center justify-center transition-colors duration-300 group-hover:bg-white group-hover:text-black">
                                    <svg aria-hidden="true" class="transition-transform duration-300 group-hover:-rotate-45" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                                </div>
                            </div>
                        </a>
                    );
                })}
                <span data-row-line aria-hidden="true" class="block h-px w-full bg-white/10"></span>
            </div>

            <!-- CTA -->
            <div class="mt-16 flex justify-center reveal-text">
                <a href="/services" data-cursor-text="VER TODO" class="group flex items-center gap-3 text-white font-medium 2xl:text-lg hover:text-purple-300 transition-colors">
                    <span>Explorar servicios</span>
                    <svg aria-hidden="true" class="w-4 h-4 2xl:w-5 2xl:h-5 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                </a>
            </div>
        </div>
    </div>
</section>
