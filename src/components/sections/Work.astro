---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

/**
 * Trabajo + prueba en una sola sección: cada caso entra con el resultado
 * de negocio que cualquier cliente entiende como titular.
 */
const proof: Record<string, { stat: string; detail: string; accent: string }> = {
  sylestudio: {
    stat: '0% COMISIONES',
    detail: 'Tienda en línea propia: catálogo, pagos y envíos bajo su control. Cada peso de cada venta se queda con la marca.',
    accent: 'text-green-400',
  },
  yatagarasu: {
    stat: 'ABRE AL INSTANTE',
    detail: 'Una experiencia que se siente como videojuego y abre de inmediato en cualquier celular. Nadie se va por esperar.',
    accent: 'text-red-400',
  },
  achronyme: {
    stat: 'DE CERO A PRODUCTO',
    detail: 'Una herramienta profesional construida completa, desde la idea hasta producción. Ningún sistema es demasiado ambicioso.',
    accent: 'text-purple-400',
  },
};

const projects = await getCollection('work');
projects.sort((a, b) => Number(b.data.year) - Number(a.data.year));
const featured = projects.find((p) => p.slug === 'sylestudio') ?? projects[0];
const rest = projects.filter((p) => p.slug !== featured.slug).slice(0, 2);
---

<section id="work" class="bg-[#050505] text-white border-t border-white/10 relative overflow-hidden">
    <div class="mx-auto max-w-[1800px] relative z-10">

        <!-- Header -->
        <div class="px-6 sm:px-12 py-24 lg:pt-32 lg:pb-20">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
                <div class="lg:col-span-5">
                    <div class="text-xs 2xl:text-sm font-mono text-purple-400 tracking-widest mb-4 reveal-text" data-readout>
                        [ 01 · PRUEBA ]
                    </div>
                    <h2 class="text-4xl sm:text-5xl md:text-6xl lg:text-6xl 2xl:text-7xl font-black tracking-tighter leading-[0.9] reveal-text">
                        RESULTADOS <br> <span class="text-purple-400"><em>reales</em>.</span>
                    </h2>
                </div>
                <div class="lg:col-span-7 flex flex-col justify-end pl-0 lg:pl-12">
                    <p class="text-lg sm:text-xl md:text-2xl lg:text-xl 2xl:text-2xl text-gray-300 font-light leading-relaxed max-w-2xl reveal-text">
                        Proyectos reales con resultados que cualquiera entiende: <span class="text-white font-medium">más control, menos costos, mejor experiencia</span>.
                    </p>
                    <a href="https://eddn.dev" target="_blank" rel="noopener noreferrer" class="group mt-6 inline-flex items-center gap-2 font-mono text-xs sm:text-sm text-gray-500 hover:text-purple-300 tracking-widest uppercase transition-colors reveal-text">
                        <span>[ ¿Vienes de ingeniería? Lo técnico vive en eddn.dev ]</span>
                        <svg aria-hidden="true" class="w-3.5 h-3.5 transition-transform group-hover:translate-x-1 group-hover:-translate-y-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M7 7h10v10"/></svg>
                    </a>
                </div>
            </div>
        </div>

        <!-- Editorial stack: cada caso = pantalla que se enciende -->
        <div class="px-6 sm:px-12 pb-28 lg:pb-36 flex flex-col gap-6">
            {featured && (
                <a
                    href={`/work/${featured.slug}`}
                    data-work-card
                    data-cursor-text="VER CASO"
                    class="group relative block overflow-hidden border border-white/10 aspect-[16/12] sm:aspect-[21/10] lg:aspect-[21/9]"
                    style={`--project-color: ${featured.data.color ?? '#ffffff'};`}
                >
                    {featured.data.cover && (
                        <div data-work-media class="absolute inset-0 will-change-transform">
                            <Image
                                src={featured.data.cover}
                                alt={featured.data.title}
                                class="absolute inset-0 w-full h-full object-cover opacity-60 transition-opacity duration-700 group-hover:opacity-90"
                            />
                        </div>
                    )}
                    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent"></div>

                    <div class="absolute inset-x-0 bottom-0 p-8 sm:p-12 flex items-end justify-between gap-6">
                        <div class="min-w-0">
                            <span data-work-meta class="font-mono text-xs sm:text-sm text-gray-300 uppercase tracking-widest">
                                {featured.data.year} · {featured.data.category} · {featured.data.title}
                            </span>
                            <div data-work-stat class={`mt-3 text-[clamp(2.2rem,6vw,6rem)] font-black tracking-tighter leading-[0.9] ${proof[featured.slug]?.accent ?? 'text-white'}`}>
                                {proof[featured.slug]?.stat ?? featured.data.title}
                            </div>
                            <p data-work-meta class="mt-4 text-gray-300 font-light leading-relaxed max-w-xl 2xl:text-lg hidden sm:block">
                                {proof[featured.slug]?.detail}
                            </p>
                        </div>
                        <div data-work-meta class="hidden sm:flex w-14 h-14 shrink-0 rounded-full border border-white/20 bg-white/5 items-center justify-center transition-all duration-300 group-hover:bg-[var(--project-color)] group-hover:border-[var(--project-color)] group-hover:-rotate-45">
                            <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M17 7H7M17 7V17" /></svg>
                        </div>
                    </div>
                </a>
            )}

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                {rest.map((project) => (
                    <a
                        href={`/work/${project.slug}`}
                        data-work-card
                        data-cursor-text="VER CASO"
                        class="group relative block overflow-hidden border border-white/10 aspect-[4/3] sm:aspect-video"
                        style={`--project-color: ${project.data.color ?? '#ffffff'};`}
                    >
                        {project.data.cover && (
                            <div data-work-media class="absolute inset-0 will-change-transform">
                                <Image
                                    src={project.data.cover}
                                    alt={project.data.title}
                                    class="absolute inset-0 w-full h-full object-cover opacity-50 transition-opacity duration-700 group-hover:opacity-85"
                                />
                            </div>
                        )}
                        <div class="absolute inset-0 bg-gradient-to-t from-black via-black/50 to-transparent"></div>

                        <div class="absolute inset-x-0 bottom-0 p-6 sm:p-8">
                            <span data-work-meta class="font-mono text-xs text-gray-300 uppercase tracking-widest">
                                {project.data.year} · {project.data.category} · {project.data.title}
                            </span>
                            <div class="mt-2 flex items-end justify-between gap-4">
                                <div data-work-stat class={`text-3xl sm:text-4xl 2xl:text-5xl font-black tracking-tighter leading-[0.95] ${proof[project.slug]?.accent ?? 'text-white'}`}>
                                    {proof[project.slug]?.stat ?? project.data.title}
                                </div>
                                <div data-work-meta class="hidden sm:flex w-11 h-11 shrink-0 rounded-full border border-white/20 bg-white/5 items-center justify-center transition-all duration-300 group-hover:bg-[var(--project-color)] group-hover:border-[var(--project-color)] group-hover:-rotate-45">
                                    <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M17 7H7M17 7V17" /></svg>
                                </div>
                            </div>
                            <p data-work-meta class="mt-3 text-gray-400 font-light leading-relaxed text-sm hidden lg:block max-w-md">
                                {proof[project.slug]?.detail}
                            </p>
                        </div>
                    </a>
                ))}
            </div>

            <div class="flex justify-center pt-8">
                <a href="/work" data-cursor-text="ARCHIVO" class="group flex items-center gap-3 text-white font-medium 2xl:text-lg hover:text-purple-300 transition-colors reveal-text">
                    <span>Ver todo el trabajo</span>
                    <svg aria-hidden="true" class="w-4 h-4 2xl:w-5 2xl:h-5 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                </a>
            </div>
        </div>
    </div>
</section>
