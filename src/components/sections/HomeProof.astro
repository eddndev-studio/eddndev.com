---
const proofs = [
  {
    title: 'Syle Studio',
    stat: '20MB -> 1MB',
    detail: 'Optimización de assets, CMS 100% custom y 0% fees de plataforma para operar bajo sus propios términos.',
    href: '/work/sylestudio',
    color: 'text-green-400',
    border: 'hover:border-green-500/40',
  },
  {
    title: 'Achronyme',
    stat: '800+ TESTS',
    detail: 'Reescritura completa en Rust y VM basada en registros para subir el estándar de rendimiento y seguridad.',
    href: '/work/achronyme',
    color: 'text-purple-400',
    border: 'hover:border-purple-500/40',
  },
  {
    title: 'Yatagarasu',
    stat: '0KB JS RUNTIME',
    detail: 'Astro y CSS procedural para lograr impacto visual fuerte sin JavaScript innecesario ni peso extra.',
    href: '/work/yatagarasu',
    color: 'text-red-400',
    border: 'hover:border-red-500/40',
  },
];
---

<section id="proof" class="bg-[#050505] text-white border-t border-white/10 relative overflow-hidden">
    <div class="mx-auto max-w-[1800px] relative z-10">
        <div class="px-6 sm:px-12 py-24 lg:pt-32 lg:pb-20">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
                <div class="lg:col-span-5">
                    <div class="text-xs 2xl:text-sm font-mono text-purple-400 tracking-widest mb-4 reveal-text">
                        [ 01 · PRUEBA ]
                    </div>
                    <h2 class="text-4xl sm:text-5xl md:text-6xl lg:text-6xl 2xl:text-7xl font-black tracking-tighter leading-[0.9] reveal-text">
                        RESULTADOS <br> <span class="text-purple-400">REALES.</span>
                    </h2>
                </div>
                <div class="lg:col-span-7 flex flex-col justify-end pl-0 lg:pl-12">
                    <p class="text-lg sm:text-xl md:text-2xl lg:text-xl 2xl:text-2xl text-gray-300 font-light leading-relaxed max-w-2xl reveal-text">
                        No vendemos una idea abstracta de innovación.
                        Mostramos <span class="text-white font-medium">decisiones técnicas concretas</span> que mejoran rendimiento, control y operación.
                    </p>
                </div>
            </div>
        </div>

        <div class="px-6 sm:px-12 pb-24 lg:pb-32">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                {proofs.map((proof) => (
                    <a
                        href={proof.href}
                        class={`group bg-[#080808] border border-white/10 ${proof.border} p-8 sm:p-10 transition-colors hover:bg-[#0b0b0b]`}
                    >
                        <div class={`font-mono text-xs tracking-widest uppercase mb-6 ${proof.color}`}>{proof.title}</div>
                        <div class="text-3xl sm:text-4xl 2xl:text-5xl font-black tracking-tighter text-white mb-4">
                            {proof.stat}
                        </div>
                        <p class="text-gray-400 font-light leading-relaxed 2xl:text-lg mb-8">
                            {proof.detail}
                        </p>
                        <div class={`flex items-center gap-3 font-medium transition-colors ${proof.color}`}>
                            <span>Ver case study</span>
                            <svg class="w-4 h-4 2xl:w-5 2xl:h-5 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M5 12h14M13 5l7 7-7 7"/>
                            </svg>
                        </div>
                    </a>
                ))}
            </div>
        </div>
    </div>
</section>
