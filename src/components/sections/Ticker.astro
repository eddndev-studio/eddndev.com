---
// Promesas que un cliente entiende — lo técnico vive en eddn.dev
const promises = [
    "NADA DE PLANTILLAS", "CADA VENTA ES TUYA", "ABRE AL INSTANTE", "SE ADMINISTRA SOLO",
    "MENOS TRABAJO MANUAL", "TU MARCA EN SERIO", "SIN COMISIONES DE PLATAFORMA",
    "DISEÑO A LA MEDIDA", "TRATO DIRECTO", "HECHO EN MÉXICO"
];
// Triple for seamless loop; second row reversed for contrast
const rowA = [...promises, ...promises, ...promises];
const reversed = [...promises].reverse();
const rowB = [...reversed, ...reversed, ...reversed];
---

<!-- Live signal: the loop speed and skew react to scroll velocity (see animations/home.js) -->
<section class="relative z-20 py-12 sm:py-16 bg-[#020202] border-y border-white/10 overflow-hidden" aria-label="Lo que obtienes">
    <div class="-rotate-1 scale-[1.03] space-y-3 sm:space-y-4">
        <!-- Row A — bold, solid/outline alternating -->
        <div class="flex whitespace-nowrap items-center w-max will-change-transform" data-marquee-row data-marquee-dir="1" data-marquee-speed="30">
            {rowA.map((p, i) => (
                <span class="flex items-center">
                    <span class={`px-5 sm:px-8 font-black uppercase tracking-tight text-2xl sm:text-4xl 2xl:text-5xl ${i % 2 === 0 ? 'text-white' : 'text-outline'}`}>{p}</span>
                    <span class="text-purple-500 text-base sm:text-xl select-none" aria-hidden="true">✦</span>
                </span>
            ))}
        </div>
        <!-- Row B — smaller, counter-scrolling, ghosted -->
        <div class="flex whitespace-nowrap items-center w-max opacity-60 will-change-transform" data-marquee-row data-marquee-dir="-1" data-marquee-speed="40">
            {rowB.map((p, i) => (
                <span class="flex items-center">
                    <span class={`px-4 sm:px-6 font-black uppercase tracking-tight text-lg sm:text-2xl ${i % 2 === 0 ? 'text-outline-purple' : 'text-white/30'}`}>{p}</span>
                    <span class="text-purple-500/50 text-xs sm:text-sm select-none" aria-hidden="true">✦</span>
                </span>
            ))}
        </div>
    </div>
</section>
