---
interface Props {
  heading?: string;
  description?: string;
  language: string;
  code: string;
  caption?: string;
}
const { heading, description, language, code, caption } = Astro.props;
const codeId = `code-snippet-${Math.random().toString(36).substring(2, 9)}`;
---
<div class="space-y-8" data-case-block>
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 reveal-text">
        <div>
            {heading && <h3 class="text-2xl font-bold text-white">{heading}</h3>}
            {description && <p class="text-gray-400 text-sm mt-2 max-w-md">{description}</p>}
        </div>
        <div class="text-xs font-mono text-gray-600 border border-white/10 px-3 py-1">
            {language}
        </div>
    </div>

    <!-- Code Window -->
    <div class="overflow-hidden border border-white/10 bg-[#111] shadow-2xl reveal-text">
        <div class="flex items-center justify-between px-4 py-3 bg-[#1a1a1a] border-b border-white/5">
            <div class="flex items-center gap-2">
                <div class="w-3 h-3 rounded-full bg-red-500/20"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500/20"></div>
                <div class="w-3 h-3 rounded-full bg-green-500/20"></div>
            </div>
            
            <!-- Tailwind Plus Elements Copy Button -->
            <button 
                command="--copy" 
                commandfor={codeId}
                type="button"
                class="group flex items-center gap-2 text-[10px] uppercase font-mono tracking-widest text-gray-500 hover:text-white transition-colors"
                title="Copiar código"
            >
                <svg class="w-3.5 h-3.5 in-data-copied:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="14" height="14" x="8" y="8" rx="2" ry="2" />
                    <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" />
                </svg>
                <svg class="w-3.5 h-3.5 hidden in-data-copied:block text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 6 9 17l-5-5" />
                </svg>
                <span class="in-data-copied:hidden">Copiar</span>
                <span class="hidden in-data-copied:block text-green-400">Copiado</span>
            </button>
        </div>
        <div class="p-6 overflow-x-auto relative">
            <el-copyable id={codeId} class="hidden">{code}</el-copyable>
            <pre class="font-mono text-sm leading-loose text-gray-300"><code>{code}</code></pre>
        </div>
    </div>

    {caption && (
        <p class="text-xs font-mono text-gray-500 text-center border-l-2 border-[var(--project-color)] pl-3 ml-4 reveal-text">
            {caption}
        </p>
    )}
</div>
