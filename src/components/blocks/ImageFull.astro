---
import { Image } from 'astro:assets';
import FadeIn from '../studio/FadeIn.astro';
interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
}
const { src, alt, caption } = Astro.props;
---
<FadeIn as="figure" class="space-y-4">
  <Image
    src={src}
    alt={alt}
    class="w-full rounded-3xl bg-neutral-100 object-cover grayscale transition duration-500 hover:grayscale-0"
  />
  {caption && (
    <figcaption class="flex items-center justify-end gap-3 text-base text-neutral-600">
      <span class="h-px w-8 bg-neutral-300" aria-hidden="true"></span>
      {caption}
    </figcaption>
  )}
</FadeIn>
