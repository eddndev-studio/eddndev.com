---
import StatList from '../studio/StatList.astro';
import StatListItem from '../studio/StatListItem.astro';
interface Props {
  items: { value: string; label: string }[];
}
const { items } = Astro.props;
---
<StatList>
  {items.map((item) => (
    <StatListItem label={item.label} value={item.value} />
  ))}
</StatList>
