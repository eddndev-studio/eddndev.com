---
import FadeIn from '../studio/FadeIn.astro';
interface Props {
  heading?: string;
  body: string;
  section?: string;
  number?: string;
}
const { heading, body, section, number } = Astro.props;
const eyebrow = section ? `${number ? `${number} · ` : ''}${section}` : undefined;
---
<FadeIn as="div" class="space-y-6">
  {eyebrow && (
    <span class="block font-display text-base font-semibold text-neutral-950">{eyebrow}</span>
  )}
  {heading && (
    <h2 class="font-display text-3xl font-medium tracking-tight text-balance text-neutral-950 sm:text-4xl">
      {heading}
    </h2>
  )}
  <div class="text-xl whitespace-pre-line text-neutral-600">
    {body}
  </div>
</FadeIn>
