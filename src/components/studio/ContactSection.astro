---
import Container from './Container.astro';
import FadeIn from './FadeIn.astro';
import Button from './Button.astro';
// Studio ContactSection — black rounded-4xl invitation panel. eddndev copy + real contact data.
interface Props {
  title?: string;
  buttonText?: string;
  buttonHref?: string;
  class?: string;
}
const {
  title = 'Cuéntame sobre tu proyecto',
  buttonText = 'Hablemos',
  buttonHref = '/contact',
  class: className,
} = Astro.props;
const hasLede = Astro.slots.has('default');
---
<Container class:list={['mt-24 sm:mt-32 lg:mt-40', className]}>
  <FadeIn class="-mx-6 rounded-4xl bg-neutral-950 px-6 py-20 sm:mx-0 sm:py-32 md:px-12">
    <div class="mx-auto max-w-4xl">
      <div class="max-w-xl">
        <h2 class="font-display text-3xl font-medium text-balance text-white sm:text-4xl">{title}</h2>
        {hasLede && <div class="mt-6 text-base text-neutral-300"><slot /></div>}
        <div class="mt-6 flex">
          <Button href={buttonHref} invert>{buttonText}</Button>
        </div>
        <div class="mt-10 border-t border-white/10 pt-10">
          <h3 class="font-display text-base font-semibold text-white">Contacto directo</h3>
          <ul role="list" class="mt-6 grid grid-cols-1 gap-8 text-sm text-neutral-300 sm:grid-cols-2">
            <li>
              <strong class="text-white">Correo</strong><br />
              <a href="mailto:contacto@eddndev.com" class="transition hover:text-white">contacto@eddndev.com</a>
            </li>
            <li>
              <strong class="text-white">WhatsApp</strong><br />
              <a href="https://wa.me/525619433938" target="_blank" rel="noopener noreferrer" class="transition hover:text-white">+52 56 1943 3938</a>
            </li>
            <li>
              <strong class="text-white">Ubicación</strong><br />
              CDMX, México · remoto
            </li>
            <li>
              <strong class="text-white">Respuesta</strong><br />
              En menos de 24 horas
            </li>
          </ul>
        </div>
      </div>
    </div>
  </FadeIn>
</Container>
