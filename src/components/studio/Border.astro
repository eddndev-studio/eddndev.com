---
// Studio Border — the signature hairline corner-mark (short solid tick + faint long rule).
interface Props {
  as?: keyof HTMLElementTagNameMap;
  position?: 'top' | 'left';
  invert?: boolean;
  class?: string;
  [key: string]: unknown;
}
const { as = 'div', position = 'top', invert = false, class: className, ...rest } = Astro.props;
const Tag = as;
const classes = [
  'relative before:absolute after:absolute',
  invert ? 'before:bg-white after:bg-white/10' : 'before:bg-neutral-950 after:bg-neutral-950/10',
  position === 'top' &&
    'before:top-0 before:left-0 before:h-px before:w-6 after:top-0 after:right-0 after:left-8 after:h-px',
  position === 'left' &&
    'before:top-0 before:left-0 before:h-6 before:w-px after:top-8 after:bottom-0 after:left-0 after:w-px',
  className,
];
---
<Tag class:list={classes} {...rest}>
  <slot />
</Tag>
