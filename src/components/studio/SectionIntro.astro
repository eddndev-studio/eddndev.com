---
import Container from './Container.astro';
import FadeIn from './FadeIn.astro';

interface Props {
  title: string;
  eyebrow?: string;
  smaller?: boolean;
  invert?: boolean;
  class?: string;
  [key: string]: unknown;
}
const { title, eyebrow, smaller = false, invert = false, class: className, ...rest } = Astro.props;
const hasLede = Astro.slots.has('default');
---
<Container class={className} {...rest}>
  <FadeIn class="max-w-2xl">
    <h2>
      {eyebrow && (
        <>
          <span class:list={['mb-6 block font-display text-base font-semibold', invert ? 'text-white' : 'text-neutral-950']}>
            {eyebrow}
          </span>
          <span class="sr-only"> - </span>
        </>
      )}
      <span
        class:list={[
          'block font-display tracking-tight text-balance',
          smaller ? 'text-2xl font-semibold' : 'text-4xl font-medium sm:text-5xl',
          invert ? 'text-white' : 'text-neutral-950',
        ]}
      >
        {title}
      </span>
    </h2>
    {hasLede && (
      <div class:list={['mt-6 text-xl', invert ? 'text-neutral-300' : 'text-neutral-600']}>
        <slot />
      </div>
    )}
  </FadeIn>
</Container>
