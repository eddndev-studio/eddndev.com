---
// Studio Button — pill. Default CTA is brand violet; `invert` is the white pill
// for dark/violet panels. `brand` stays as an explicit alias (same as default).
interface Props {
  href?: string;
  invert?: boolean;
  brand?: boolean;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  [key: string]: unknown;
}
const { href, invert = false, brand = false, type = 'button', class: className, ...rest } = Astro.props;
const variant = brand
  ? 'bg-brand-button text-white hover:bg-brand-mid'
  : invert
    ? 'bg-white text-neutral-950 hover:bg-neutral-200'
    : 'bg-brand-button text-white hover:bg-brand-mid';
const classes = [
  'inline-flex rounded-full px-4 py-1.5 text-sm font-semibold transition',
  variant,
  className,
];
---
{href ? (
  <a href={href} class:list={classes} {...rest}>
    <span class="relative top-px"><slot /></span>
  </a>
) : (
  <button type={type} class:list={classes} {...rest}>
    <span class="relative top-px"><slot /></span>
  </button>
)}
