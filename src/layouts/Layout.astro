---
import '../styles/global.css';
import '@tailwindplus/elements';
import { ClientRouter } from 'astro:transitions';
import SiteNav from '../components/studio/SiteNav.astro';
import Footer from '../components/studio/Footer.astro';
import GridPattern from '../components/studio/GridPattern.astro';

interface Props {
	title?: string;
    description?: string;
    image?: string | ImageMetadata;
    project?: { title: string };
    breadcrumbs?: { name: string; url: string }[];
}

const {
    title = "edd n' dev — Ingeniería digital freelance",
    description = "Soy Eduardo Alonso (eddndev), ingeniero digital freelance en México. Diseño y construyo sitios web, e-commerce, automatización y software a medida.",
    image,
    project,
    breadcrumbs = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// JSON-LD: Person (freelance personal brand)
const personLD = {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Eduardo Alonso",
    "alternateName": "eddndev",
    "jobTitle": "Ingeniero digital freelance",
    "url": "https://eddndev.com",
    "image": "https://eddndev.com/favicon.png",
    "description": "Ingeniero digital freelance en México. Sitios web, e-commerce, automatización y software a medida.",
    "sameAs": [
        "https://github.com/eddndev",
        "https://www.linkedin.com/in/eddndev",
        "https://x.com/eddndev",
        "https://instagram.com/eddn.dev",
        "https://tiktok.com/@eddndev",
        "https://threads.net/@eddn.dev",
        "https://eddn.dev"
    ],
    "email": "contacto@eddndev.com",
    "knowsLanguage": ["es", "en"]
};

// JSON-LD: WebSite (only on homepage)
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '';
const webSiteLD = isHome ? {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "edd n' dev",
    "url": "https://eddndev.com",
    "description": description,
    "inLanguage": "es"
} : null;

// JSON-LD: BreadcrumbList (when breadcrumbs provided)
const breadcrumbLD = breadcrumbs.length > 0 ? {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://eddndev.com" },
        ...breadcrumbs.map((crumb, i) => ({
            "@type": "ListItem",
            "position": i + 2,
            "name": crumb.name,
            "item": new URL(crumb.url, "https://eddndev.com").href
        }))
    ]
} : null;

// Dynamic OG Generator Base URL hosted on the new OG subdomain
const defaultOgUrl = new URL('https://og.eddndev.com/generate');
defaultOgUrl.searchParams.set('title', title);
defaultOgUrl.searchParams.set('tag', 'eddndev');
defaultOgUrl.searchParams.set('og_type', project ? 'Project' : 'Page');

const resolvedImage = image || defaultOgUrl.href;

let socialImageURL = "";
if (typeof resolvedImage === 'string') {
    if (resolvedImage.startsWith('http')) {
        socialImageURL = resolvedImage;
    } else {
        socialImageURL = new URL(resolvedImage, Astro.site).href;
    }
} else if (resolvedImage && typeof resolvedImage === 'object' && 'src' in resolvedImage) {
    socialImageURL = new URL(resolvedImage.src, Astro.site).href;
}
---

<!doctype html>
<html lang="es" class="h-full">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png">
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />

        <!-- Set early so reveal targets only hide when scripting is live -->
        <script is:inline>document.documentElement.classList.add('js');</script>

        <!-- SEO / Metadata -->
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalURL} />
        <meta name="generator" content={Astro.generator} />
        <meta name="theme-color" content="#ffffff" />

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={Astro.url} />
        <meta property="og:locale" content="es_MX" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={socialImageURL} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:type" content="image/png" />
        <meta property="og:image:alt" content={`Portada de: ${title}`} />

        <!-- Twitter -->
        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={Astro.url} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={socialImageURL} />
        <meta property="twitter:image:alt" content={`Portada de: ${title}`} />

        <!-- Fonts (self-hosted) -->
        <link rel="preload" href="/fonts/Mona-Sans.var.woff2" as="font" type="font/woff2" crossorigin />

        <!-- JSON-LD Structured Data -->
        <script type="application/ld+json" set:html={JSON.stringify(personLD)} />
        {webSiteLD && <script type="application/ld+json" set:html={JSON.stringify(webSiteLD)} />}
        {breadcrumbLD && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLD)} />}

        <ClientRouter />
	</head>
	<body class="flex min-h-full flex-col bg-neutral-950 text-neutral-950 antialiased">
        <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[10000] focus:rounded-full focus:bg-neutral-950 focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-white">
            Saltar al contenido
        </a>

        <SiteNav />

        <!-- White page card — pushed down by the nav panel to reveal the menu -->
        <div data-nav-content class="relative flex flex-auto overflow-hidden rounded-t-4xl bg-white pt-14">
            <div class="relative isolate flex w-full flex-col pt-9">
                <GridPattern
                    class="absolute inset-x-0 -top-14 -z-10 h-[1000px] w-full mask-[linear-gradient(to_bottom_left,white_40%,transparent_50%)] fill-neutral-50 stroke-neutral-950/5"
                    yOffset={-96}
                    interactive
                />
                <main id="main-content" class="w-full flex-auto" data-project-title={project?.title}>
                    <slot />
                </main>
                <Footer />
            </div>
        </div>

        <script src="../scripts/main.js"></script>
	</body>
</html>
