---
import '../styles/global.css';
import '@tailwindplus/elements';
import SvgSprite from '../components/SvgSprite.astro';
import { ClientRouter } from 'astro:transitions';
import DockNav from '../components/layout/DockNav.astro';
import NavigationPanel from '../components/layout/NavigationPanel.astro';

interface Props {
	title?: string;
    description?: string;
    image?: string | ImageMetadata;
    project?: { title: string };
    breadcrumbs?: { name: string; url: string }[];
}

const {
    title = "edd n' dev — Ingeniería digital freelance",
    description = "Soy Eduardo Alonso (eddndev), ingeniero digital freelance en México. Diseño y construyo sitios web, e-commerce, automatización y software a medida.",
    image,
    project,
    breadcrumbs = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// JSON-LD: Person (freelance personal brand)
const personLD = {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Eduardo Alonso",
    "alternateName": "eddndev",
    "jobTitle": "Ingeniero digital freelance",
    "url": "https://eddndev.com",
    "image": "https://eddndev.com/favicon.png",
    "description": "Ingeniero digital freelance en México. Sitios web, e-commerce, automatización y software a medida.",
    "sameAs": [
        "https://github.com/eddndev",
        "https://www.linkedin.com/in/eddndev",
        "https://x.com/eddndev",
        "https://instagram.com/eddn.dev",
        "https://tiktok.com/@eddndev",
        "https://threads.net/@eddn.dev",
        "https://eddn.dev"
    ],
    "email": "contacto@eddndev.com",
    "knowsLanguage": ["es", "en"]
};

// JSON-LD: WebSite (only on homepage)
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '';
const webSiteLD = isHome ? {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "edd n' dev",
    "url": "https://eddndev.com",
    "description": description,
    "inLanguage": "es"
} : null;

// JSON-LD: BreadcrumbList (when breadcrumbs provided)
const breadcrumbLD = breadcrumbs.length > 0 ? {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://eddndev.com" },
        ...breadcrumbs.map((crumb, i) => ({
            "@type": "ListItem",
            "position": i + 2,
            "name": crumb.name,
            "item": new URL(crumb.url, "https://eddndev.com").href
        }))
    ]
} : null;

// Dynamic OG Generator Base URL hosted on the new OG subdomain
const defaultOgUrl = new URL('https://og.eddndev.com/generate');
defaultOgUrl.searchParams.set('title', title);
defaultOgUrl.searchParams.set('tag', 'eddndev');
defaultOgUrl.searchParams.set('og_type', project ? 'Project' : 'Page');

const resolvedImage = image || defaultOgUrl.href;

// Resolve image URL
let socialImageURL = "";
if (typeof resolvedImage === 'string') {
    // If it's already an absolute URL (like our generator), use it directly, otherwise resolve it
    if (resolvedImage.startsWith('http')) {
        socialImageURL = resolvedImage;
    } else {
        socialImageURL = new URL(resolvedImage, Astro.site).href;
    }
} else if (resolvedImage && typeof resolvedImage === 'object' && 'src' in resolvedImage) {
    // Handle ImageMetadata (from Content Collections or imports)
    socialImageURL = new URL(resolvedImage.src, Astro.site).href;
}
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png">
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
        
        <!-- SEO / Metadata -->
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalURL} />
        <meta name="generator" content={Astro.generator} />
        <meta name="theme-color" content="#050505" />

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={Astro.url} />
        <meta property="og:locale" content="es_MX" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={socialImageURL} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:type" content="image/png" />
        <meta property="og:image:alt" content={`Portada de: ${title}`} />

        <!-- Twitter -->
        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={Astro.url} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={socialImageURL} />
        <meta property="twitter:image:alt" content={`Portada de: ${title}`} />

        <!-- Fonts (self-hosted) -->
		
        <!-- JSON-LD Structured Data -->
        <script type="application/ld+json" set:html={JSON.stringify(personLD)} />
        {webSiteLD && <script type="application/ld+json" set:html={JSON.stringify(webSiteLD)} />}
        {breadcrumbLD && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLD)} />}

        <ClientRouter />
	</head>
	<body class="bg-black text-white antialiased overflow-x-hidden">
        <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[10000] focus:px-4 focus:py-2 focus:bg-purple-600 focus:text-white focus:rounded focus:text-sm focus:font-bold">
            Saltar al contenido
        </a>

        <div id="custom-cursor" transition:persist class="hidden lg:flex fixed top-0 left-0 z-[9999] pointer-events-none w-4 h-4 rounded-full bg-white mix-blend-difference items-center justify-center transform -translate-x-1/2 -translate-y-1/2 will-change-[width,height,transform]">
            <span id="cursor-label" class="text-xs font-black text-white opacity-0 tracking-widest font-mono uppercase whitespace-nowrap"></span>
        </div>

        <SvgSprite />
        
        <div class="min-h-screen bg-black">
            
            <!-- 1. INFRASTRUCTURE — floating dock nav (fixed bottom) -->
            <DockNav project={project} />
            
            <!-- 2. NAVIGATION GRID (Overlay under Header, right of Sidebar) -->
            <NavigationPanel />

            <!-- 3. PAGE CONTENT (Scrollable area) -->
            <!-- Heroes manage their own top padding (no fixed top bar) -->
            <!-- Left padding creates space for the fixed Sidebar -->
            <div 
                id="page-content"
                class="flex flex-col min-w-0 relative z-10 bg-black transition-opacity duration-500"
            >
                <main id="main-content" class="flex-1 relative z-10" data-project-title={project?.title}>
                    <slot />
                </main>
            </div>
        </div>

        <script src="../scripts/main.js"></script>
	</body>
</html>