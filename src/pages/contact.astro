---
import Layout from '../layouts/Layout.astro';
import Container from '../components/studio/Container.astro';
import FadeIn from '../components/studio/FadeIn.astro';
import PageIntro from '../components/studio/PageIntro.astro';
import SectionIntro from '../components/studio/SectionIntro.astro';
import Border from '../components/studio/Border.astro';
import List from '../components/studio/List.astro';
import ListItem from '../components/studio/ListItem.astro';
import TagList from '../components/studio/TagList.astro';
import TagListItem from '../components/studio/TagListItem.astro';

// Lo que me ayuda a responder mejor (copy original preservado)
const briefing = [
  'Qué necesitas construir o mejorar.',
  'Qué problema de negocio quieres resolver.',
  'Si ya existe una web, tienda, sistema o proceso manual.',
  'Tiempos, alcance y cualquier restricción importante.',
];

// Métodos de contacto (copy original preservado)
const methods = [
  {
    label: 'Correo',
    value: 'contacto@eddndev.com',
    href: 'mailto:contacto@eddndev.com',
    detail: 'Ideal para proyectos con contexto, alcance o requerimientos específicos. Respondo en menos de 24 horas.',
  },
  {
    label: 'Chat directo',
    value: '+52 56 1943 3938',
    href: 'https://wa.me/525619433938',
    external: true,
    detail: 'Mejor para primeras preguntas, validar encaje o coordinar una llamada breve.',
  },
];

// Datos operativos (copy original preservado)
const facts = [
  { label: 'Respuesta', value: '< 24 horas' },
  { label: 'Base', value: 'México · GMT-6' },
];

// Redes (copy original preservado)
const socials = [
  { label: 'LinkedIn', url: 'https://linkedin.com/in/eddndev' },
  { label: 'GitHub', url: 'https://github.com/eddndev' },
  { label: 'Instagram', url: 'https://instagram.com/eddn.dev' },
  { label: 'Achronyme', url: 'https://github.com/achronyme' },
];
---

<Layout
    title="Contacto — edd n' dev"
    description="Escríbeme con el problema y la meta del proyecto. Respondo en menos de 24 horas."
    breadcrumbs={[{ name: "Contacto", url: "/contact" }]}
>
  <!-- HERO -->
  <PageIntro eyebrow="Respuesta en menos de 24 h" title="Cuéntame qué necesitas.">
    <p>
      Escríbeme con el problema y la meta del proyecto. Te digo cómo abordarlo, qué conviene
      construir y si soy la persona correcta para hacerlo.
    </p>
  </PageIntro>

  <!-- MÉTODOS DE CONTACTO -->
  <Container class="mt-24 sm:mt-32 lg:mt-40">
    <div class="grid grid-cols-1 gap-x-8 gap-y-16 lg:grid-cols-3">
      <div class="lg:col-span-2">
        <FadeIn>
          <h2 class="font-display text-base font-semibold text-neutral-950">Cómo escribirme</h2>
        </FadeIn>
        <div class="mt-10 grid grid-cols-1 gap-8 sm:grid-cols-2">
          {methods.map((method) => (
            <FadeIn>
              <Border class="pt-8">
                <h3 class="font-display text-base font-semibold text-neutral-950">{method.label}</h3>
                <a
                  href={method.href}
                  {...(method.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                  class="mt-4 block font-display text-2xl font-medium tracking-tight text-neutral-950 break-words transition hover:text-neutral-600 sm:text-3xl"
                >
                  {method.value}
                </a>
                <p class="mt-4 text-base text-neutral-600">{method.detail}</p>
              </Border>
            </FadeIn>
          ))}
        </div>
      </div>

      <FadeIn class="lg:col-span-1">
        <Border class="pt-8">
          <h2 class="font-display text-base font-semibold text-neutral-950">En corto</h2>
          <dl class="mt-6 grid grid-cols-1 gap-6">
            {facts.map((fact) => (
              <div>
                <dt class="text-sm text-neutral-600">{fact.label}</dt>
                <dd class="mt-1 font-display text-xl font-medium text-neutral-950">{fact.value}</dd>
              </div>
            ))}
            <div>
              <dt class="text-sm text-neutral-600">Ubicación</dt>
              <dd class="mt-1 font-display text-xl font-medium text-neutral-950">CDMX, México · remoto</dd>
            </div>
          </dl>
        </Border>
      </FadeIn>
    </div>
  </Container>

  <!-- ANTES DE ESCRIBIR -->
  <SectionIntro
    eyebrow="Antes de escribir"
    title="Qué me ayuda a responderte mejor."
    class="mt-24 sm:mt-32 lg:mt-40"
  >
    <p>Entre más claro el contexto, mejor te puedo decir cómo abordarlo y qué conviene construir.</p>
  </SectionIntro>
  <Container class="mt-16">
    <List>
      {briefing.map((item) => (
        <ListItem>{item}</ListItem>
      ))}
    </List>
  </Container>

  <!-- REDES -->
  <SectionIntro
    eyebrow="Redes"
    title="También me encuentras aquí."
    class="mt-24 sm:mt-32 lg:mt-40"
  />
  <Container class="mt-12">
    <FadeIn>
      <TagList>
        {socials.map((social) => (
          <TagListItem class="transition hover:bg-neutral-200">
            <a href={social.url} target="_blank" rel="noopener noreferrer">{social.label}</a>
          </TagListItem>
        ))}
      </TagList>
    </FadeIn>
  </Container>
</Layout>
