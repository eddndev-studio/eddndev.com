---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Container from '../components/studio/Container.astro';
import FadeIn from '../components/studio/FadeIn.astro';
import FadeInStagger from '../components/studio/FadeInStagger.astro';
import Button from '../components/studio/Button.astro';
import SectionIntro from '../components/studio/SectionIntro.astro';
import List from '../components/studio/List.astro';
import ListItem from '../components/studio/ListItem.astro';
import StylizedImage from '../components/studio/StylizedImage.astro';
import ContactSection from '../components/studio/ContactSection.astro';
import { services } from '../data/services';
import profileImg from '../assets/images/profile.jpg';

// Manifiesto de encaje — cuándo entra una solución propia (copy original, verbatim)
const manifesto = [
  'Tu marca necesita presencia con identidad — y una web que convierta visitas en clientes.',
  'Quieres una base propia que se adapte exactamente a cómo operas.',
  'Tu equipo pierde horas en trabajo que debería ejecutarse solo.',
  'Te importa cómo se ve tanto como que funcione en serio.',
];

// Promesas que un cliente entiende — lo técnico vive en eddn.dev (copy original)
const promises = [
  '100% a la medida de tu marca', 'Cada venta es 100% tuya', 'Abre al instante', 'Se administra solo',
  'Menos trabajo manual', 'Tu marca en serio', 'Tus márgenes, completos',
  'Diseño a la medida', 'Trato directo', 'Hecho en México',
];

// Trabajo + prueba: cada caso entra con su resultado de negocio (copy original)
const proof = {
  sylestudio: { stat: '0% comisiones', detail: 'Tienda en línea propia: catálogo, pagos y envíos bajo su control. Cada peso de cada venta se queda con la marca.' },
  yatagarasu: { stat: 'Abre al instante', detail: 'Una experiencia que se siente como videojuego y abre de inmediato en cualquier celular. Nadie se va por esperar.' },
  achronyme: { stat: 'De cero a producto', detail: 'Una herramienta profesional construida completa, desde la idea hasta producción. Cualquier sistema, por ambicioso que sea, lo construyo completo.' },
};

const projects = await getCollection('work');
projects.sort((a, b) => Number(b.data.year) - Number(a.data.year));
const featured = projects.find((p) => p.slug === 'sylestudio') ?? projects[0];
const ordered = [featured, ...projects.filter((p) => p.slug !== featured.slug)].slice(0, 3);
---

<Layout
    title="edd n' dev — Ingeniería digital freelance"
    description="Soy Eduardo Alonso (eddndev). Diseño y construyo sitios web, e-commerce, automatizaciones y software a medida con infraestructura propia, desde México."
>
  <!-- HERO -->
  <Container class="mt-24 sm:mt-32 md:mt-48">
    <FadeIn class="max-w-3xl">
      <div class="flex items-center gap-x-3 text-sm font-semibold tracking-wide text-neutral-950">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-500 opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
        </span>
        Ingeniería digital freelance · Disponible para proyectos
      </div>
      <h1 class="mt-6 font-display text-5xl font-medium tracking-tight text-balance text-neutral-950 sm:text-7xl">
        Sitios que <em class="italic">venden</em>. Sistemas que <em class="italic">trabajan</em>.
      </h1>
      <p class="mt-6 text-xl text-neutral-600">
        Soy Eduardo. Construyo la presencia digital de marcas que quieren verse serias y vender más
        — sitios, tiendas en línea y automatización, todo hecho a la medida de tu marca.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-4">
        <Button href="/contact">Cuéntame tu proyecto</Button>
        <a href="#work" class="group inline-flex items-center gap-2 text-sm font-semibold text-neutral-950 transition hover:text-neutral-600">
          Ver casos de estudio
          <svg aria-hidden="true" class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>
    </FadeIn>
  </Container>

  <!-- PROMESAS (Studio "clients" band) -->
  <div class="mt-24 rounded-4xl panel-brand py-20 sm:mt-32 sm:py-24 lg:mt-40">
    <Container>
      <FadeIn class="flex items-center gap-x-8">
        <h2 class="text-center font-display text-sm font-semibold tracking-wider text-white sm:text-left">
          Lo que obtienes al trabajar conmigo
        </h2>
        <div class="h-px flex-auto bg-neutral-800"></div>
      </FadeIn>
      <FadeInStagger faster>
        <ul role="list" class="mt-10 grid grid-cols-2 gap-x-8 gap-y-6 sm:grid-cols-3 lg:grid-cols-5">
          {promises.map((promise) => (
            <FadeIn as="li" class="font-display text-base font-semibold text-neutral-300">{promise}</FadeIn>
          ))}
        </ul>
      </FadeInStagger>
    </Container>
  </div>

  <!-- ENCAJE -->
  <SectionIntro
    eyebrow="Encaje"
    title="Cuando quieres algo hecho a tu medida."
    class="mt-24 sm:mt-32 lg:mt-40"
  >
    <p>Entro cuando hace falta una base propia y una solución técnicamente seria. <a href="/profile" class="font-semibold text-neutral-950 underline decoration-1 underline-offset-2">Conoce quién está detrás →</a></p>
  </SectionIntro>
  <Container class="mt-16">
    <List>
      {manifesto.map((item) => (
        <ListItem>{item}</ListItem>
      ))}
    </List>
  </Container>

  <!-- TRABAJO / PRUEBA -->
  <SectionIntro
    eyebrow="Prueba"
    title="Resultados reales."
    id="work"
    class="mt-24 sm:mt-32 lg:mt-40"
  >
    <p>Proyectos reales con resultados que cualquiera entiende: más control, menos costos, mejor experiencia.</p>
  </SectionIntro>
  <Container class="mt-16">
    <FadeInStagger class="grid grid-cols-1 gap-8 lg:grid-cols-3">
      {ordered.map((project) => (
        <FadeIn class="group flex">
          <article class="relative flex w-full flex-col rounded-3xl p-6 ring-1 ring-neutral-950/5 transition hover:bg-neutral-50 sm:p-8">
            {project.data.cover && (
              <Image src={project.data.cover} alt={project.data.title} class="aspect-16/10 w-full rounded-2xl object-cover grayscale transition duration-500 group-hover:grayscale-0" />
            )}
            <h3 class="mt-6 font-display text-2xl font-semibold text-neutral-950">
              <a href={`/work/${project.slug}`}>
                <span class="absolute inset-0 rounded-3xl"></span>
                {project.data.title}
              </a>
            </h3>
            <p class="mt-2 flex gap-x-2 text-sm text-neutral-950">
              <time datetime={String(project.data.year)} class="font-semibold">{project.data.year}</time>
              <span class="text-neutral-300" aria-hidden="true">/</span>
              <span>{project.data.category}</span>
            </p>
            <p class="mt-4 text-base text-neutral-600">{proof[project.slug]?.detail}</p>
            {proof[project.slug]?.stat && (
              <p class="mt-6 font-display text-sm font-semibold tracking-wider text-neutral-950 uppercase">{proof[project.slug].stat}</p>
            )}
          </article>
        </FadeIn>
      ))}
    </FadeInStagger>
    <FadeIn class="mt-12 flex justify-center">
      <a href="/work" class="group inline-flex items-center gap-2 text-sm font-semibold text-neutral-950 transition hover:text-neutral-600">
        Ver todo el trabajo
        <svg aria-hidden="true" class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </FadeIn>
  </Container>

  <!-- SERVICIOS -->
  <SectionIntro
    eyebrow="Servicios"
    title="Lo que construyo."
    class="mt-24 sm:mt-32 lg:mt-40"
  >
    <p>Cuatro líneas de servicio, un mismo estándar: soluciones propias que escalan con tu negocio.</p>
  </SectionIntro>
  <Container class="mt-16">
    <div class="lg:flex lg:items-center lg:justify-end">
      <div class="flex justify-center lg:w-1/2 lg:justify-end lg:pr-12">
        <FadeIn class="w-135 flex-none lg:w-180">
          <StylizedImage src={profileImg} alt="Eduardo Alonso — eddndev" class="justify-center lg:justify-end" />
        </FadeIn>
      </div>
      <List class="mt-16 lg:mt-0 lg:w-1/2 lg:min-w-132 lg:pl-4">
        {services.map((service) => (
          <ListItem title={service.title}>{service.tagline}.</ListItem>
        ))}
      </List>
    </div>
    <FadeIn class="mt-12 flex justify-center">
      <a href="/services" class="group inline-flex items-center gap-2 text-sm font-semibold text-neutral-950 transition hover:text-neutral-600">
        Explorar servicios
        <svg aria-hidden="true" class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </FadeIn>
  </Container>

  <!-- CTA -->
  <ContactSection
    title="Tu proyecto empieza aquí."
    buttonText="Cuéntame tu proyecto"
  />
</Layout>
