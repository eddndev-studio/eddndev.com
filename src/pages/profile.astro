---
import Layout from '../layouts/Layout.astro';
import Container from '../components/studio/Container.astro';
import FadeIn from '../components/studio/FadeIn.astro';
import PageIntro from '../components/studio/PageIntro.astro';
import SectionIntro from '../components/studio/SectionIntro.astro';
import List from '../components/studio/List.astro';
import ListItem from '../components/studio/ListItem.astro';
import GridList from '../components/studio/GridList.astro';
import GridListItem from '../components/studio/GridListItem.astro';
import StylizedImage from '../components/studio/StylizedImage.astro';
import ContactSection from '../components/studio/ContactSection.astro';
import profileImg from '../assets/images/profile.jpg';

// Lo que me diferencia — copy original preservado del diseño anterior
const values = [
  {
    title: 'Infraestructura gestionada',
    body: 'Administro servidores dedicados, seguridad y rendimiento. Tú te enfocas en tu negocio, yo me encargo de que todo funcione.',
  },
  {
    title: 'Automatización con criterio',
    body: 'Identifico los procesos que le cuestan tiempo y dinero a tu operación y construyo flujos a medida que trabajan sin que tengas que pensar en ellos.',
  },
  {
    title: 'Velocidad que se siente',
    body: 'Un sistema lento es un sistema que pierde clientes. Construyo software que abre al instante y consume menos recursos — lo que se traduce en menos gasto mensual para tu negocio.',
  },
  {
    title: 'Sistemas, no páginas',
    body: 'Diseño la lógica completa de tu operación digital para que funcione con la misma seriedad que tu negocio exige.',
  },
];

// Cómo trabajo — pasos del proceso, copy original preservado
const process = [
  {
    title: 'Entender antes de proponer',
    body: 'Antes de escribir una sola línea, entiendo cómo opera tu negocio, qué le duele y qué necesita para crecer. Si la mejor solución es no construir nada, te lo digo.',
  },
  {
    title: 'Diseñar con intención',
    body: 'Cada decisión de diseño y arquitectura tiene una razón. No agrego complejidad innecesaria ni funciones que nadie va a usar.',
  },
  {
    title: 'Construir para durar',
    body: 'Elijo las herramientas correctas para cada problema, las que de verdad le sirven a tu negocio. Lo que entrego funciona hoy y sigue funcionando en tres años.',
  },
  {
    title: 'Operar sin que lo notes',
    body: 'Me encargo de la infraestructura, las actualizaciones y la seguridad de forma continua. Tu sistema evoluciona y se mantiene estable sin que tengas que intervenir.',
  },
];
---

<Layout
    title="Perfil — edd n' dev"
    description="Soy Eduardo Alonso (eddndev), ingeniero digital freelance. Construyo sistemas que controlas por completo, hechos para tu negocio."
    breadcrumbs={[{ name: "Perfil", url: "/profile" }]}
>
  <!-- HERO -->
  <PageIntro eyebrow="eddndev · Ingeniería digital · México" title="Construyo independencia.">
    <p>
      Tu negocio necesita sistemas propios que trabajan para ti y que controlas por completo.
      Eso es lo que construyo.
    </p>
  </PageIntro>

  <!-- QUIÉN SOY -->
  <SectionIntro
    eyebrow="Quién soy"
    title="Ingeniería con nombre y apellido."
    class="mt-24 sm:mt-32 lg:mt-40"
  >
    <p>Construyo sistemas completos: desde la infraestructura donde vive tu proyecto hasta la interfaz que tocan tus usuarios.</p>
  </SectionIntro>
  <Container class="mt-16">
    <div class="lg:flex lg:items-start lg:gap-x-12">
      <div class="flex justify-center lg:w-1/2 lg:justify-start">
        <FadeIn class="w-135 flex-none lg:w-180">
          <figure>
            <StylizedImage src={profileImg} alt="Eduardo Alonso, eddndev" shape={1} />
            <figcaption class="mt-4 text-sm text-neutral-600">Eduardo Alonso · México · desde 2020</figcaption>
          </figure>
        </FadeIn>
      </div>
      <FadeIn class="mt-12 lg:mt-0 lg:w-1/2">
        <div class="typography text-neutral-600">
          <p>
            Soy <strong class="font-semibold text-neutral-950">Eduardo Alonso</strong> — eddndev. Ingeniero digital
            independiente desde 2020, en México. Construyo sistemas completos: desde la infraestructura
            donde vive tu proyecto hasta la interfaz que tocan tus usuarios.
          </p>
          <p>
            Gestiono servidores, seguridad, rendimiento y actualizaciones —
            <strong class="font-semibold text-neutral-950">todo pasa por mis manos</strong>.
            Trato directo de principio a fin: hablas con la misma persona que construye tu proyecto.
          </p>
          <p>
            ¿Te interesa el detalle técnico? Documento cómo pienso y construyo en
            <a href="https://eddn.dev" target="_blank" rel="noopener noreferrer" class="font-semibold text-neutral-950 underline decoration-1 underline-offset-2">eddn.dev</a>.
          </p>
        </div>
      </FadeIn>
    </div>
  </Container>

  <!-- LO QUE ME IMPORTA -->
  <SectionIntro
    eyebrow="Lo que me importa"
    title="Lo que me diferencia."
    class="mt-24 sm:mt-32 lg:mt-40"
  >
    <p>Cuatro principios que guían cada proyecto que construyo.</p>
  </SectionIntro>
  <Container class="mt-16">
    <GridList class="lg:grid-cols-2">
      {values.map((value) => (
        <GridListItem title={value.title}>{value.body}</GridListItem>
      ))}
    </GridList>
  </Container>

  <!-- CÓMO TRABAJO -->
  <SectionIntro
    eyebrow="Proceso"
    title="Cómo trabajo."
    class="mt-24 sm:mt-32 lg:mt-40"
  >
    <p>
      Cada proyecto es diferente, pero mi obsesión es la misma: que lo que construya
      resuelva un problema real y que no necesites un manual de 200 páginas para usarlo.
    </p>
  </SectionIntro>
  <Container class="mt-16">
    <List>
      {process.map((step) => (
        <ListItem title={step.title}>{step.body}</ListItem>
      ))}
    </List>
  </Container>

  <!-- FILOSOFÍA -->
  <SectionIntro
    eyebrow="Filosofía"
    title="Tu proyecto, mi obsesión."
    class="mt-24 sm:mt-32 lg:mt-40"
  >
    <p>
      Infraestructura, código, seguridad y evolución continua —
      gestiono cada capa para que tu proyecto funcione sin fricciones.
    </p>
  </SectionIntro>

  <!-- CTA -->
  <ContactSection
    title="Tu proyecto, mi obsesión."
    buttonText="Hablemos de tu proyecto"
  />
</Layout>
