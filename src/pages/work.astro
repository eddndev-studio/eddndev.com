---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/layout/Footer.astro';
import ProjectList from '../components/work/ProjectList.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('work');
projects.sort((a, b) => (Number(b.data.year) - Number(a.data.year)));

const years = projects.map((p) => Number(p.data.year));
const archiveSpan = `${Math.min(...years)} — ${Math.max(...years)}`;
const archiveCount = String(projects.length).padStart(2, '0');
---

<Layout
    title="Proyectos — edd n' dev"
    description="Proyectos seleccionados: sitios, e-commerce, software y sistemas construidos desde cero para marcas reales."
    breadcrumbs={[{ name: "Proyectos", url: "/work" }]}
>
    <!-- HERO -->
    <div id="hero" class="relative min-h-[100dvh] w-full flex flex-col justify-center lg:justify-end pt-32 pb-0 lg:pb-24 overflow-hidden border-b border-white/10">
      <!-- Ambient blob -->
      <div class="absolute bottom-0 right-0 translate-x-1/3 translate-y-1/3 w-[800px] h-[800px] rounded-full bg-purple-500 opacity-[0.07] blur-[150px] pointer-events-none z-0"></div>

      <!-- Fondo Animado Específico para Work -->
      <div id="ledding-work-container" class="absolute inset-0 z-0 opacity-40"></div>

      <!-- Scrim: protege la columna de texto sin apagar la matriz -->
      <div aria-hidden="true"
           class="absolute inset-0 pointer-events-none z-[5]"
           style="background: linear-gradient(105deg, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.8) 34%, rgba(0,0,0,0.45) 58%, rgba(0,0,0,0.12) 78%, transparent 92%);">
      </div>

      <!-- Vignette -->
      <div id="hero-vignette"
           class="absolute inset-0 bg-gradient-to-t from-black/90 via-transparent to-transparent pointer-events-none z-10">
      </div>

      <!-- Contenido Principal -->
      <div class="relative z-20 w-full px-6 sm:px-12 max-w-[1800px] mx-auto">
        <header class="flex flex-col items-start">
          <div class="flex items-center gap-3 mb-4 lg:mb-6">
            <div class="w-2 h-2 bg-purple-500 rounded-full animate-pulse shadow-[0_0_8px_#a855f7]"></div>
            <span data-readout class="font-mono text-xs sm:text-sm 2xl:text-base tracking-widest uppercase text-gray-300">[ ARCHIVO · {archiveCount} CASOS · {archiveSpan} ]</span>
          </div>

          <h1 class="font-black tracking-tighter text-white leading-[0.85] text-[clamp(3.5rem,11vw,12rem)] 2xl:text-[clamp(5rem,11vw,16rem)] drop-shadow-[0_4px_28px_rgba(0,0,0,0.85)]">
            PROYECTOS <br>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-purple-200">SELECCIONADOS</span>
          </h1>

          <div class="mt-8 lg:mt-12 grid grid-cols-1 lg:grid-cols-12 gap-8 w-full border-t border-white/10 pt-8">
            <div class="lg:col-span-5">
              <p class="text-lg sm:text-xl md:text-2xl lg:text-xl 2xl:text-2xl text-gray-300 font-light leading-relaxed max-w-xl 2xl:max-w-2xl">
                Sistemas reales construidos para <span class="text-white font-medium">marcas reales</span> — del concepto a producción.
              </p>
            </div>
          </div>
        </header>
      </div>
    </div>

    <!-- ARCHIVE LIST -->
    <div class="bg-black relative z-10">
        <ProjectList projects={projects} />
    </div>

    <!-- Floating preview: follows the cursor over the list (desktop) -->
    <div data-work-preview aria-hidden="true" class="fixed top-0 left-0 z-[60] pointer-events-none hidden lg:block w-[24rem] 2xl:w-[28rem] aspect-[16/10] overflow-hidden border border-white/15 bg-[#0a0a0a] shadow-[0_24px_80px_rgba(0,0,0,0.7)]">
        <img data-work-preview-img src="" alt="" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-repeat opacity-10 pointer-events-none mix-blend-overlay" style="background-image: linear-gradient(0deg, transparent 24%, rgba(255, 255, 255, .3) 25%, rgba(255, 255, 255, .3) 26%, transparent 27%, transparent 74%, rgba(255, 255, 255, .3) 75%, rgba(255, 255, 255, .3) 76%, transparent 77%, transparent), linear-gradient(90deg, transparent 24%, rgba(255, 255, 255, .3) 25%, rgba(255, 255, 255, .3) 26%, transparent 27%, transparent 74%, rgba(255, 255, 255, .3) 75%, rgba(255, 255, 255, .3) 76%, transparent 77%, transparent); background-size: 4px 4px;"></div>
    </div>

    <Footer />
</Layout>
