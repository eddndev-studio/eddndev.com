---
import Layout from '../layouts/Layout.astro';
import Container from '../components/studio/Container.astro';
import PageIntro from '../components/studio/PageIntro.astro';
import ContactSection from '../components/studio/ContactSection.astro';
import ProjectGrid from '../components/work/ProjectGrid.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('work');
projects.sort((a, b) => (Number(b.data.year) - Number(a.data.year)));
---

<Layout
    title="Proyectos — edd n' dev"
    description="Proyectos seleccionados: sitios, e-commerce, software y sistemas construidos desde cero para marcas reales."
    breadcrumbs={[{ name: "Proyectos", url: "/work" }]}
>
    <!-- HERO -->
    <PageIntro eyebrow="Archivo" title="Proyectos seleccionados.">
      <p>
        Sistemas reales construidos para <span class="font-semibold text-neutral-950">marcas reales</span> — del concepto a producción.
      </p>
    </PageIntro>

    <!-- ARCHIVO -->
    <Container class="mt-24 sm:mt-32 lg:mt-40">
      <ProjectGrid projects={projects} />
    </Container>

    <!-- CTA -->
    <ContactSection
      title="Tu proyecto empieza aquí."
      buttonText="Cuéntame tu proyecto"
    />
</Layout>
