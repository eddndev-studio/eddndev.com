---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/layout/Footer.astro';
import NextProject from '../../components/work/NextProject.astro';

export async function getStaticPaths() {
  const projects = await getCollection('work');
  const sorted = [...projects].sort((a, b) => Number(b.data.year) - Number(a.data.year));
  return sorted.map(entry => ({
    params: { slug: entry.slug },
    props: { entry, projects: sorted },
  }));
}

const { entry, projects } = Astro.props;
const { Content } = await entry.render();

// Dynamic CSS variable for project color
function hexToRgb(hex) {
    let c;
    if(/^#([A-Fa-f0-9]{3}){1,2}$/.test(hex)){
        c= hex.substring(1).split('');
        if(c.length== 3){
            c= [c[0], c[0], c[1], c[1], c[2], c[2]];
        }
        c= '0x'+c.join('');
        return [(c>>16)&255, (c>>8)&255, c&255].join(',');
    }
    return '255,255,255';
}

const colorStyle = `--project-color: ${entry.data.color}; --project-color-rgb: ${hexToRgb(entry.data.color)}`;

// Case index within the archive — the hero reads like a dossier
const caseIndex = projects.findIndex(p => p.slug === entry.slug);
const caseNum = String(caseIndex + 1).padStart(2, '0');
const caseTotal = String(projects.length).padStart(2, '0');

const role = entry.data.role ?? 'Diseño & construcción';

const LINK_LABELS: Record<string, string> = {
    'Live Site': 'Sitio en vivo',
    'Documentation': 'Documentación',
};
const links = Object.entries(entry.data.links ?? {});
---

<Layout
    title={`${entry.data.title} — edd n' dev`}
    description={entry.data.description}
    image={entry.data.cover}
    project={{ title: entry.data.title }}
    breadcrumbs={[
        { name: "Proyectos", url: "/work" },
        { name: entry.data.title, url: `/work/${entry.slug}` }
    ]}
>

    <!-- Dynamic Style Wrapper -->
    <div style={colorStyle}>

        <!-- HERO — the case powers on like a dossier on an LED wall -->
        <header data-case-hero class={`relative w-full min-h-[100dvh] flex flex-col overflow-hidden border-b border-white/10 ${entry.data.heroStyle || 'bg-[#020202]'}`}>

            <!-- LED matrix (brand signature — config keyed by this id) -->
            <div id="ledding-project-container" class="absolute inset-0 z-0 opacity-40 mix-blend-screen pointer-events-none"></div>

            <!-- Scrim: protege la columna de texto sin apagar la matriz a la derecha -->
            <div aria-hidden="true"
                 class="absolute inset-0 pointer-events-none z-[5]"
                 style="background: linear-gradient(105deg, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.82) 34%, rgba(0,0,0,0.5) 58%, rgba(0,0,0,0.14) 78%, transparent 92%);">
            </div>

            <!-- Corner frame in project color -->
            <div data-case-corner aria-hidden="true" class="absolute top-0 left-0 w-10 h-10 border-t border-l z-10 origin-top-left opacity-50" style="border-color: var(--project-color)"></div>
            <div data-case-corner aria-hidden="true" class="absolute top-0 right-0 w-10 h-10 border-t border-r z-10 origin-top-right opacity-50" style="border-color: var(--project-color)"></div>

            <!-- Top meta row -->
            <div class="relative z-20 w-full max-w-[1800px] mx-auto px-6 sm:px-12 pt-24 sm:pt-28 flex items-center justify-between gap-4 font-mono text-xs tracking-widest uppercase">
                <a href="/work" data-readout data-cursor-text="VOLVER" aria-label="Volver a todos los casos" class="text-gray-400 hover:text-white transition-colors">[ ← TRABAJO ]</a>
                <span data-readout class="text-gray-500">[ CASO {caseNum} / {caseTotal} ]</span>
            </div>

            <!-- Center: massive title + editorial intro -->
            <div data-case-heroinner class="relative z-20 flex-1 flex flex-col justify-center w-full max-w-[1800px] mx-auto px-6 sm:px-12 pt-16 pb-28">
                <div class="flex items-center gap-3 mb-6">
                    <span data-case-rule aria-hidden="true" class="h-px w-12 origin-left" style="background: var(--project-color); box-shadow: 0 0 8px var(--project-color)"></span>
                    <span data-readout class="font-mono text-xs sm:text-sm tracking-[0.2em] uppercase" style="color: var(--project-color)">[ {entry.data.category} · {entry.data.year} ]</span>
                </div>

                <h1 data-case-title class="font-black tracking-tighter text-white leading-[0.84] text-[clamp(3.25rem,12vw,12.5rem)] drop-shadow-[0_4px_28px_rgba(0,0,0,0.85)]">
                    {entry.data.title.toUpperCase()}<span class="inline-block animate-pulse" style="color: var(--project-color); text-shadow: 0 0 24px var(--project-color)">.</span>
                </h1>

                <div class="mt-10 lg:mt-14 grid grid-cols-1 lg:grid-cols-12 gap-8">
                    <p data-case-intro class="lg:col-span-6 text-lg sm:text-xl 2xl:text-2xl text-gray-300 font-light leading-relaxed max-w-2xl">
                        {entry.data.description}
                    </p>
                </div>
            </div>

        </header>

        <!-- Spec bar — values flip in like an LED board as you reach it -->
        <div data-case-specs class="relative z-20 grid grid-cols-2 md:grid-cols-4 border-b border-white/10 divide-x divide-white/10 bg-[#030303]">
            <div data-spec-cell class="p-6 sm:p-8">
                <div class="font-mono text-[10px] tracking-widest uppercase mb-2" style="color: var(--project-color)">[ AÑO ]</div>
                <div data-spec-value class="text-xl font-bold text-white font-mono">{entry.data.year}</div>
            </div>
            <div data-spec-cell class="p-6 sm:p-8">
                <div class="font-mono text-[10px] tracking-widest uppercase mb-2" style="color: var(--project-color)">[ ROL ]</div>
                <div data-spec-value class="text-xl font-bold text-white">{role}</div>
            </div>
            <div data-spec-cell class="p-6 sm:p-8 col-span-2">
                <div class="font-mono text-[10px] tracking-widest uppercase mb-3" style="color: var(--project-color)">[ STACK ]</div>
                <div class="flex flex-wrap gap-2">
                    {entry.data.stack.map(tech => (
                        <span data-spec-chip class="font-mono text-xs rounded-full border border-white/15 bg-white/5 px-3 py-1 text-gray-300">{tech}</span>
                    ))}
                </div>
            </div>
        </div>

        <!-- ACCESOS — direct links as magnetic chips -->
        {links.length > 0 && (
        <section data-case-access class="relative z-20 bg-[#030303] border-b border-white/10">
            <div class="mx-auto max-w-[1800px] px-6 sm:px-12 py-8 sm:py-10 flex flex-col md:flex-row md:items-center gap-5 md:gap-10">
                <span data-readout class="font-mono text-xs tracking-widest uppercase shrink-0" style="color: var(--project-color)">[ ACCESOS ]</span>
                <div class="flex flex-wrap gap-3">
                    {links.map(([label, url]) => (
                        <a href={url} target="_blank" rel="noopener noreferrer" data-access-chip data-magnetic="0.4" data-cursor-text="ABRIR"
                           class="group inline-flex items-center gap-3 rounded-full border border-white/15 bg-white/[0.04] pl-5 pr-2 py-2 font-mono text-sm text-gray-300 hover:text-white hover:border-[var(--project-color)] transition-colors">
                            <span>{LINK_LABELS[label] ?? label}</span>
                            <span class="w-7 h-7 rounded-full bg-white/5 flex items-center justify-center transition-colors group-hover:bg-[var(--project-color)]">
                                <svg aria-hidden="true" class="w-3 h-3 transition-transform duration-300 group-hover:rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M7 7h10v10"/></svg>
                            </span>
                        </a>
                    ))}
                </div>
            </div>
        </section>
        )}

        <!-- EXPEDIENTE — reading column with progress rail + margin numerals -->
        <section class="bg-[#050505] relative z-10 pb-32 overflow-hidden">
            <!-- Ambient blobs -->
            <div class="absolute top-[10%] -left-[200px] w-[600px] h-[600px] rounded-full bg-[var(--project-color)] opacity-[0.06] blur-[150px] pointer-events-none z-0"></div>
            <div class="absolute bottom-[20%] -right-[150px] w-[500px] h-[500px] rounded-full bg-[var(--project-color)] opacity-[0.05] blur-[120px] pointer-events-none z-0"></div>

            <!-- Outer guides -->
            <div class="absolute inset-0 max-w-[1800px] mx-auto pointer-events-none px-6 sm:px-12" aria-hidden="true">
                <div class="absolute left-6 sm:left-12 top-0 bottom-0 w-px bg-white/5"></div>
                <div class="absolute right-6 sm:right-12 top-0 bottom-0 w-px bg-white/5"></div>
            </div>

            <div class="mx-auto max-w-[1800px] px-6 sm:px-12 relative" data-case-content>
                <div class="relative max-w-4xl mx-auto py-24 lg:py-32">
                    <!-- Reading rail: fills in project color as you read -->
                    <div aria-hidden="true" class="hidden xl:block absolute -left-12 top-24 bottom-24 w-px bg-white/5">
                        <div data-case-rail class="absolute inset-0 origin-top" style="background: var(--project-color); box-shadow: 0 0 12px rgba(var(--project-color-rgb), 0.45)"></div>
                    </div>

                    <div class="space-y-24 lg:space-y-32">
                        <Content />
                    </div>
                </div>
            </div>
        </section>

        <!-- NEXT PROJECT -->
        <NextProject current={entry} projects={projects} />
    </div>

    <Footer />
</Layout>
