---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Container from '../../components/studio/Container.astro';
import FadeIn from '../../components/studio/FadeIn.astro';
import PageIntro from '../../components/studio/PageIntro.astro';
import StatList from '../../components/studio/StatList.astro';
import StatListItem from '../../components/studio/StatListItem.astro';
import TagList from '../../components/studio/TagList.astro';
import TagListItem from '../../components/studio/TagListItem.astro';
import ContactSection from '../../components/studio/ContactSection.astro';
import NextProject from '../../components/work/NextProject.astro';

export async function getStaticPaths() {
  const projects = await getCollection('work');
  const sorted = [...projects].sort((a, b) => Number(b.data.year) - Number(a.data.year));
  return sorted.map(entry => ({
    params: { slug: entry.slug },
    props: { entry, projects: sorted },
  }));
}

const { entry, projects } = Astro.props;
const { Content } = await entry.render();

const role = entry.data.role ?? 'Diseño & construcción';

const LINK_LABELS: Record<string, string> = {
    'Live Site': 'Sitio en vivo',
    'Documentation': 'Documentación',
};
const links = Object.entries(entry.data.links ?? {});
---

<Layout
    title={`${entry.data.title} — edd n' dev`}
    description={entry.data.description}
    image={entry.data.cover}
    project={{ title: entry.data.title }}
    breadcrumbs={[
        { name: "Proyectos", url: "/work" },
        { name: entry.data.title, url: `/work/${entry.slug}` }
    ]}
>
    <!-- HERO -->
    <PageIntro eyebrow={entry.data.category} title={entry.data.title}>
        <p>{entry.data.description}</p>
    </PageIntro>

    <!-- META: año / rol / stack / accesos -->
    <Container class="mt-16">
        <StatList>
            <StatListItem label="Año" value={String(entry.data.year)} />
            <StatListItem label="Rol" value={role} />
        </StatList>

        <FadeIn class="mt-12">
            <h2 class="font-display text-base font-semibold text-neutral-950">Stack</h2>
            <TagList class="mt-4">
                {entry.data.stack.map((tech) => (
                    <TagListItem>{tech}</TagListItem>
                ))}
            </TagList>
        </FadeIn>

        {links.length > 0 && (
            <FadeIn class="mt-12">
                <h2 class="font-display text-base font-semibold text-neutral-950">Accesos</h2>
                <ul role="list" class="mt-4 flex flex-wrap gap-x-8 gap-y-3">
                    {links.map(([label, url]) => (
                        <li>
                            <a
                                href={url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="group inline-flex items-center gap-2 text-sm font-semibold text-neutral-950 transition hover:text-neutral-600"
                            >
                                {LINK_LABELS[label] ?? label}
                                <svg aria-hidden="true" class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M7 7h10v10"/></svg>
                            </a>
                        </li>
                    ))}
                </ul>
            </FadeIn>
        )}
    </Container>

    <!-- EXPEDIENTE — long-form MDX prose -->
    <Container class="mt-24 sm:mt-32 lg:mt-40">
        <div class="typography mx-auto max-w-4xl">
            <Content />
        </div>
    </Container>

    <!-- NEXT PROJECT -->
    <NextProject current={entry} projects={projects} />

    <!-- CTA -->
    <ContactSection title="Tu proyecto empieza aquí." buttonText="Cuéntame tu proyecto" />
</Layout>
